+from fastapi import FastAPI, HTTPException
+from sqlmodel import Session, select, create_engine
+from backend.app.models import Inmueble, Agente #, create_db_and_tables
+
+# Database setup
+# For simplicity, using an in-memory SQLite for now.
+# Replace with actual database URL for production.
DATABASE_URL = "sqlite:///./database.db"
engine = create_engine(DATABASE_URL)
+
+# Dependency to get a DB session
+def get_session():
+    with Session(engine) as session:
+        yield session
+
+
+app = FastAPI()
+
+# @app.on_event("startup")
+# def on_startup():
+# create_db_and_tables() # Uncomment if you want tables to be created on startup
+
+
+@app.get("/api/inmuebles", response_model=List[Inmueble])
+def listar_inmuebles():
+    with Session(engine) as session:
+        statement = select(Inmueble).where(Inmueble.estado == "disponible")
+        results = session.exec(statement).all()
+        return results
+
+
+@app.get("/api/inmuebles/{id}", response_model=Inmueble)
+def detalle_inmueble(id: int):
+    with Session(engine) as session:
+        inmueble = session.get(Inmueble, id)
+        if not inmueble:
+            raise HTTPException(status_code=404, detail="Inmueble no encontrado")
+        return inmueble
+
+
+@app.post("/api/agentes/inmuebles", response_model=Inmueble)
+def crear_inmueble(inmueble: Inmueble):
+    with Session(engine) as session:
+        session.add(inmueble)
+        session.commit()
+        session.refresh(inmueble)
+        return inmueble
+
+# Placeholder for authentication
+def get_current_agente():
+    # This would involve token verification, etc.
+    # For now, just a placeholder.
+    return Agente(id=1, nombre="Agente Demo", email="agente@demo.com", hashed_password="hashed_password")
+
+
+@app.put("/api/agentes/inmuebles/{id}", response_model=Inmueble)
+def actualizar_inmueble(id: int, inmueble_update: Inmueble):
+    with Session(engine) as session:
+        inmueble = session.get(Inmueble, id)
+        if not inmueble:
+            raise HTTPException(status_code=404, detail="Inmueble no encontrado")
+        for key, value in inmueble_update.dict(exclude_unset=True).items():
+            setattr(inmueble, key, value)
+        session.add(inmueble)
+        session.commit()
+        session.refresh(inmueble)
+        return inmueble
+
+
+@app.delete("/api/agentes/inmuebles/{id}")
+def eliminar_inmueble(id: int):
+    with Session(engine) as session:
+        inmueble = session.get(Inmueble, id)
+        if not inmueble:
+            raise HTTPException(status_code=404, detail="Inmueble no encontrado")
+        session.delete(inmueble)
+        session.commit()
+        return {"message": "Inmueble eliminado"}